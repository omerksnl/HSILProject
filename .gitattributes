# Normalize text files to LF in repo
* text=auto eol=lf

# Windows script files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tif binary
*.tiff binary
*.zip binary
*.gz binary
*.7z binary
*.pdf binary
*.h5 binary
*.keras binary
